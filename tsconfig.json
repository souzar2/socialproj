{
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES6",
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true
  },
  "include": ["src/**/*", "tsconfig.json"],
  "exclude": ["dist"],
  "typeRoots": ["./src/types", "./node_modules/@types"]
}